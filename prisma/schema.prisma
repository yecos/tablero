generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  spaces        Space[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Space {
  id          String    @id @default(cuid())
  name        String
  description String?
  icon        String    @default("🎨")
  color       String    @default("#6366f1")
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  designs     Design[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Design {
  id        String   @id @default(cuid())
  title     String
  type      String
  prompt    String?
  imageUrl  String?
  result    String?
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  category    String
  prompt      String
  mode        String
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ApiUsage {
  id         String   @id @default(cuid())
  userId     String?
  provider   String
  mode       String
  tokensUsed Int?
  duration   Int?
  success    Boolean
  createdAt  DateTime @default(now())
}
