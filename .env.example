# Database — SQLite for local dev (Vercel uses its own env var)
DATABASE_URL="file:./dev.db"

# ── AI Provider API Keys ──────────────────────────────────────────────────────
# At least one provider per category should be configured for the app to work.
# The system automatically falls back through available providers.

# Text Generation: ZAI SDK (always available) → Google Gemini → Groq → OpenRouter → Cerebras
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=

# Image Generation: ZAI SDK (always available) → Pollinations (free, no key) → Together → HuggingFace → fal.ai
TOGETHER_API_KEY=
HF_TOKEN=
FAL_API_KEY=

# 3D Generation: Hunyuan3D Gradio (always available) → Tripo3D → SF3D → fal.ai
TRIPO_API_KEY=
# HF_TOKEN (shared with image gen)
# FAL_API_KEY (shared with image gen)

# Design Utilities
REMOVEBG_API_KEY=
CLIPDROP_API_KEY=
VECTORIZER_API_KEY=
# HF_TOKEN (shared, used for Rembg + Style Transfer + Vectorize)
# FAL_API_KEY (shared, used for Style Transfer)

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=
